{
  "version": 2,
  "installCommand": "cd pawflow-frontend && npm install",
  "buildCommand": "cd pawflow-frontend && npm run build",
  "outputDirectory": "pawflow-frontend/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
